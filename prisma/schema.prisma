// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output = "./generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Subscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

model Admin {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  email            String    @unique
  password         String    // Hashed
  role             String    @default("admin") // e.g. "superadmin", "admin"
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("admins")
}

model ContactForm {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_forms")
}

model Manuscript {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  author      String
  email       String
  phone       String?
  description String?
  fileName    String
  fileUrl     String?  // Cloudinary URL after upload
  fileType    String   // PDF, DOC, DOCX
  fileSize    Int      // Size in bytes
  status      String   @default("pending") // pending, approved, rejected
  cloudinaryId String? // For deletion if needed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("manuscripts")
}

model BlogPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  slug      String?  @unique
  author    String
  email     String
  content   String
  category  String?
  imageName String
  imageUrl  String?  // Cloudinary URL after upload
  imageSize Int      // Size in bytes
  status    String   @default("pending") // pending, published, rejected
  cloudinaryId String? // For deletion if needed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}
